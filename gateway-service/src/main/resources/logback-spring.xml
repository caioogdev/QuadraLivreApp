<configuration>
    <springProperty name="appName" source="spring.application.name"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="PAPERTRAIL" class="ch.qos.logback.classic.net.SyslogAppender">
        <syslogHost>syslog.collector.na-01.cloud.solarwinds.com</syslogHost>
        <port>6514</port>
        <facility>USER</facility>
        <suffixPattern>[4_anFlP-t2E0CVwQ06WAkJNw2b1XDWk5hDM-tnjLcB9BIkPr0nURUC8S6k0mfjQDhGrZ8io] ${appName} %thread %-5level %logger{36} - %msg</suffixPattern>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="PAPERTRAIL"/>
    </root>
</configuration>